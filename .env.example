# AI Development Multi-Agent System Configuration
# Copy this file to .env and modify the values as needed

# Host workspace directory to mount in containers
# This should be the absolute path to your project directory
WORKSPACE_HOST_PATH=/home/developer/workspace

# Agent ports (change if ports are already in use)
PLANNER_AGENT_PORT=8080
ARCHITECT_AGENT_PORT=8081
CODER_AGENT_PORT=8082
TESTER_AGENT_PORT=8083

# External service ports
NGINX_PORT=8090

# Amazon Q Configuration
# Replace with your actual Amazon Q instance URL
AMAZON_Q_START_URL=https://your-amazon-q-instance.awsapps.com/start
AMAZON_Q_REGION=us-east-1

# Slack Configuration for notifications
# Get these values from your Slack app configuration
AMAZON_Q_SLACK_OAUTH_TOKEN=xoxb-your-slack-bot-token
AMAZON_Q_SLACK_USER_ID=U1234567890

# Notion Configuration for documentation
# Get these values from your Notion integration
NOTION_API_TOKEN=secret_your-notion-integration-token
NOTION_DATABASE_ID=your-database-id-here
NOTION_WORKSPACE_URL=https://www.notion.so/your-workspace

# AWS Configuration for CLI and services
# Get these from your AWS account
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Database configuration
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=testdb
MYSQL_USER=testuser
MYSQL_PASSWORD=testpass

POSTGRES_DB=dev_history
POSTGRES_USER=planner
POSTGRES_PASSWORD=planner123

# Redis configuration (leave empty for no password)
REDIS_PASSWORD=

# Development environment
NODE_ENV=development
DEBUG=true
