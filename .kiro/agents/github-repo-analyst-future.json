    "prompt": "file://../../.shared-ai/prompts/github-repo-analyst-future.md",
    "tools": ["read", "write", "shell", "web"],
    "allowedTools": ["web", "shell"],
    "toolsSettings": {
        "write": {
            "allowedPaths": ["Documents/works/scout_histories/github_repo_analysis/**"]
        },
        "shell": {
            "allowedCommands": [
                "gh api *",
                "gh issue list *",
                "gh pr list *"
            ]
        }
    },
    "resources": [],
    "includeMcpJson": false,
    "model": "claude-sonnet-4",
    "welcomeMessage": "リポジトリの将来の方向性を調査します。"
}
