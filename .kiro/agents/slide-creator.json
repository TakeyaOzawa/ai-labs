{
    "name": "slide-creator",
    "description": "勉強会資料作成エージェント。テーマのヒアリングからアウトライン設計、文面作成、Google Slidesへの反映までを一貫して行う。",
    "prompt": "file://./prompts/slide-creator.md",
    "tools": ["read", "write", "shell", "web"],
    "allowedTools": ["web"],
    "toolsSettings": {
        "write": {
            "allowedPaths": ["docs/slides/**"]
        },
        "shell": {
            "allowedCommands": ["gws slides *", "gws schema *"]
        }
    },
    "resources": [],
    "model": "claude-sonnet-4",
    "welcomeMessage": "勉強会資料の作成をお手伝いします。まずテーマを教えてください。対象者・発表時間・トーンなどもあればお知らせください。"
}
