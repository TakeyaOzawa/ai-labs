    "prompt": "file://../../.shared-ai/prompts/gws-digest-scout.md",
    "tools": ["read", "write", "shell"],
    "allowedTools": ["shell"],
    "toolsSettings": {
        "write": {
            "allowedPaths": ["Documents/works/scout_histories/gws_trends/weekly/**"]
        },
        "read": {
            "allowedPaths": [
                "Documents/works/scout_histories/gws_trends/**"
            ]
        }
    },
    "resources": [],
    "includeMcpJson": true,
    "model": "claude-sonnet-4",
    "welcomeMessage": "GWS週次ダイジェストの収集を開始します。過去1週間のGWSドキュメント更新を集約し、種別・関連度別にサマリーを作成します。"
}
