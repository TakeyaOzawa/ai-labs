{
    "name": "github-repo-analyst",
    "description": "GitHub APIを使用してリポジトリのメタデータ・履歴・計画を総合的に調査するエージェント。README、構造、依存関係、CI/CD、リリース、コミット、コントリビューター、Issues/PRsを一括調査する。",
    "prompt": "file://../../.shared-ai/prompts/github-repo-analyst.md",
    "tools": ["read", "write", "shell"],
    "allowedTools": ["shell"],
    "toolsSettings": {
        "write": {
            "allowedPaths": ["~/Documents/works/scout_reports/github_repo_analysis/**"]
        },
        "shell": {
            "allowedCommands": [
                "gh api *",
                "gh repo view *",
                "python3.12 ~/scripts/get-jst-date.py *",
                "date *"
            ]
        }
    },
    "resources": [],
    "includeMcpJson": false,
    "model": "claude-sonnet-4",
    "welcomeMessage": "GitHub APIでリポジトリを総合調査します。"
}
