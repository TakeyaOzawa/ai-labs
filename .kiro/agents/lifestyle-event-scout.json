{
    "name": "lifestyle-event-scout",
    "description": "ライフスタイルイベントスカウト。曜日別ローテーションで12カテゴリのイベント情報を日次収集する。月:お出かけ、火:体験、水:文化、木:学び、金:食と暮らし、土:マネーと人生、日:週次サマリー。",
    "prompt": "file://../../.shared-ai/prompts/lifestyle-event-scout.md",
    "tools": ["read", "write", "web"],
    "allowedTools": ["web"],
    "toolsSettings": {
        "write": {
            "allowedPaths": [
                "Documents/works/scout_histories/lifestyle_events/daily/**",
                "Documents/works/scout_histories/lifestyle_events/weekly/**"
            ]
        }
    },
    "resources": [],
    "includeMcpJson": false,
    "model": "claude-sonnet-4",
    "welcomeMessage": "ライフスタイルイベントの収集を開始します。曜日テーマを判定し、該当カテゴリのイベントを検索してレポートを作成します。"
}
