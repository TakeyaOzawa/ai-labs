{
    "name": "slack-notifier",
    "description": "指定されたmdファイルまたはテキストをSlackチャンネルに投稿する汎用通知エージェント（notify-slack.py経由）",
    "prompt": "file://../../.shared-ai/prompts/slack-notifier.md",
    "tools": ["read", "shell"],
    "allowedTools": [],
    "toolsSettings": {
        "read": {
            "allowedPaths": [
                "Documents/works/scout_histories/**",
                "Documents/works/research_materials/**",
                "Documents/works/jobs/**"
            ]
        }
    },
    "resources": [],
    "includeMcpJson": false,
    "model": "claude-sonnet-4",
    "welcomeMessage": "Slack通知エージェントです。投稿するファイルパスとチャンネルIDを指定してください。"
}
