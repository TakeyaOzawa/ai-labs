apiVersion: v1
kind: PersistentVolume
metadata:
  name: shared-workspace-pv
  labels:
    type: hostpath
spec:
  capacity:
    storage: 50Gi
  accessModes:
  - ReadWriteMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: shared-workspace
  hostPath:
    path: ${WORKSPACE_HOST_PATH}
    type: Directory
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: shared-workspace-pvc
  namespace: ai-agents
spec:
  accessModes:
  - ReadWriteMany
  resources:
    requests:
      storage: 50Gi
  storageClassName: shared-workspace
