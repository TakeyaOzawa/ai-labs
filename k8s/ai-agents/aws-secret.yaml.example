apiVersion: v1
kind: Secret
metadata:
  name: aws-secret
  namespace: ai-agents
type: Opaque
data:
  # Base64 encoded values - replace with your actual values
  # echo -n "your-access-key-id" | base64
  access_key_id: XXXXXXXXXXXXXXXXXX==  # your-access-key-id
  # echo -n "your-secret-access-key" | base64
  secret_access_key: XXXXXXXXXXXXXXXXXX==  # your-secret-access-key
