#!/bin/zsh
# pre-commit hook: .shared-ai/ 配下の変更時に構造検証を実行する
#
# .shared-ai/rules/, .shared-ai/lookups/, .shared-ai/references/,
# .kiro/steering/, scripts/resolve-shared-ai-rules.py 等の変更がある場合、
# verify-shared-ai-structure.py を実行して全チェック PASS を強制する。

# ステージされたファイルに対象パスが含まれるか確認
TARGETS=(
    ".shared-ai/rules/"
    ".shared-ai/lookups/"
    ".shared-ai/references/"
    ".shared-ai/interfaces/"
    ".kiro/steering/"
    "scripts/resolve-shared-ai-rules.py"
    "scripts/setup-symlinks.py"
    "scripts/verify-shared-ai-structure.py"
    "scripts/ai-cli-utils.py"
    ".claude/CLAUDE.md"
    ".gemini/GEMINI.md"
    ".codex/AGENTS.md"
)

STAGED_FILES=$(git diff --cached --name-only)
SHOULD_VERIFY=false

for target in "${TARGETS[@]}"; do
    if echo "$STAGED_FILES" | grep -q "$target"; then
        SHOULD_VERIFY=true
        break
    fi
done

if [ "$SHOULD_VERIFY" = false ]; then
    exit 0
fi

echo "🔍 .shared-ai 構造変更を検出。verify-shared-ai-structure.py を実行します..."
echo ""

python3.12 ~/scripts/verify-shared-ai-structure.py
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo ""
    echo "❌ 構造検証に失敗しました。コミットを中断します。"
    echo "   修正後に再度コミットしてください。"
    echo ""
    echo "   💡 スキップする場合: git commit --no-verify"
    exit 1
fi

echo ""
echo "✅ 構造検証 PASS"
exit 0
